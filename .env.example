# === GPU Configuration ===
# Auto-detected if not set. Options: cuda, cpu
# DEVICE=cuda

# === Model Storage ===
# Where downloaded model weights are cached
MODELS_DIR=./models

# Where trained models from Audio-Trainer are stored
TRAINED_MODELS_DIR=./checkpoints

# === Output ===
OUTPUTS_DIR=./outputs
AUDIO_OUTPUT_FORMAT=wav

# === Server ===
HOST=0.0.0.0
PORT=8000

# === Generation Limits ===
MAX_DURATION_SECONDS=60

# === MusicGen ===
# Options: facebook/musicgen-small, facebook/musicgen-medium, facebook/musicgen-large
DEFAULT_MUSIC_MODEL=facebook/musicgen-small

# === HuggingFace ===
# Required for gated models
# HF_TOKEN=
